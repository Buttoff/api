<Window x:Class="CalcClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="400" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Строка 0: Число A -->
        <Label Grid.Row="0" Grid.Column="0" Content="Число A:" Margin="5"/>
        <TextBox x:Name="TextBoxA" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" Padding="3"/>

        <!-- Строка 1: Число B -->
        <Label Grid.Row="1" Grid.Column="0" Content="Число B:" Margin="5"/>
        <TextBox x:Name="TextBoxB" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="3"/>

        <!-- Строка 2: Кнопка Рассчитать и результат -->
        <Button x:Name="CalculateButton" Grid.Row="2" Grid.Column="0" Content="Рассчитать" Margin="5" Padding="10,5" Click="CalculateButton_Click"/>
        <TextBox x:Name="ResultTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="3" IsReadOnly="True"/>

        <Button x:Name="CreateResourceButton" Grid.Row="2" Grid.Column="2" Content="Создать (REST)" Margin="5" Padding="10,5" Click="CreateResourceButton_Click"/>
        <!-- Строка 3: Кнопка Показать историю -->
        <Button x:Name="HistoryButton" Grid.Row="3" Grid.Column="0" Content="Показать историю" Margin="5" Padding="10,5" Click="HistoryButton_Click"/>
        <ProgressBar x:Name="LoadingProgressBar" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Height="20" IsIndeterminate="True" Visibility="Collapsed"/>

        <!-- Строка 4: Удаление по ID -->
        <Label Grid.Row="4" Grid.Column="0" Content="ID для удаления:" Margin="5"/>
        <TextBox x:Name="DeleteIdTextBox" Grid.Row="4" Grid.Column="1" Margin="5" Padding="3"/>
        <Button x:Name="DeleteButton" Grid.Row="4" Grid.Column="3" Content="Удалить" Margin="5" Padding="10,5" Click="DeleteButton_Click" Background="#FFFFE0E0"/>
        <Button x:Name="UpdateButton" Grid.Row="5" Grid.Column="3" Content="Обновить" Margin="5" Padding="10,5" Click="UpdateButton_Click" Background="#FFE0FFE0"/>
        
        <!-- Строка 5: Кнопка быстрого вычисления (GET) -->
        <Button x:Name="QuickCalcButton" Grid.Row="5" Grid.Column="0" Content="Быстро (GET)" Margin="5" Padding="10,5" Click="QuickCalcButton_Click"/>
        <TextBox x:Name="QuickResultTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="3" IsReadOnly="True"/>

        <Button x:Name="DtoPostButton" Grid.Row="6" Grid.Column="0" Content="DTO POST" Margin="5,5,5,70" Padding="10,5" Click="DtoPostButton_Click"/>
        <Button x:Name="DtoListButton" Grid.Row="6" Grid.Column="1" Content="DTO список" Margin="5,5,5,70" Padding="10,5" Click="DtoListButton_Click"/>
        <Button x:Name="StatsButton" Grid.Row="6" Grid.Column="2" Content="Статистика" Margin="5,5,5,70" Padding="10,5" Click="StatsButton_Click"/>

        <!-- Строка 7: Список истории -->
        <ListBox x:Name="HistoryListBox" Grid.Row="6" Grid.ColumnSpan="3" Margin="5,70,5,5" DisplayMemberPath="DisplayText"/>
    </Grid>
</Window>